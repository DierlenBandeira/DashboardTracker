{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dashboardtracker-pb4e.onrender.com/:path*"
    },
    {
      "source": "/calc_dist",
      "destination": "/calc_dist.html"
    },
    {
      "source": "/treatment",
      "destination": "/treatment.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}